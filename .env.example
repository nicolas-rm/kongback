# ─────────────────────────────────────────────
# Database (PostgreSQL / Supabase)
# ─────────────────────────────────────────────

# URL de conexión con pooling — usada en runtime por la aplicación
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# URL directa sin pooling — usada exclusivamente por Prisma para migraciones
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────

# Puerto en el que escucha el servidor HTTP
PORT=3000

# Entorno de ejecución: development | production | test
NODE_ENV=development

# Nombre de la aplicación — aparece en correos, encabezados y el issuer de 2FA
APP_NAME="My App"

# URL base del frontend — usada en CORS, correos de recuperación y WebSockets
APP_WEB_URL="http://localhost:4200"

# ─────────────────────────────────────────────
# OIDC / SSO (Google + Microsoft)
# ─────────────────────────────────────────────

# Permite crear usuarios automáticamente cuando el proveedor devuelve un email válido
OIDC_AUTO_PROVISION_USERS=true

# URL base a la que el backend redirige tras completar el callback OIDC
OIDC_POST_LOGIN_REDIRECT_URL="http://localhost:4200"

# Google
OIDC_GOOGLE_ENABLED=false
OIDC_GOOGLE_CLIENT_ID=""
OIDC_GOOGLE_CLIENT_SECRET=""
OIDC_GOOGLE_REDIRECT_URI="http://localhost:3000/api/oidc/google/callback"
OIDC_GOOGLE_SCOPES="openid email profile"

# Microsoft Entra ID / Azure AD
OIDC_MICROSOFT_ENABLED=false
OIDC_MICROSOFT_CLIENT_ID=""
OIDC_MICROSOFT_CLIENT_SECRET=""
OIDC_MICROSOFT_REDIRECT_URI="http://localhost:3000/api/oidc/microsoft/callback"
OIDC_MICROSOFT_SCOPES="openid email profile User.Read"
OIDC_MICROSOFT_TENANT_ID="organizations"

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────

# Secreto para firmar los access tokens (mínimo 32 caracteres)
JWT_ACCESS_SECRET="change-me-access-secret"

# Tiempo de expiración del access token (ej. 15m, 1h)
JWT_ACCESS_EXPIRES_IN="15m"

# Secreto para firmar los refresh tokens (mínimo 32 caracteres)
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Tiempo de expiración del refresh token (ej. 3h, 7d)
JWT_REFRESH_EXPIRES_IN="3h"

# ─────────────────────────────────────────────
# Sessions & login protection
# ─────────────────────────────────────────────

# Minutos de inactividad antes de cerrar la sesión automáticamente
SESSION_IDLE_TIMEOUT_MINUTES=60

# Intervalo en segundos para renovar el timestamp de actividad de la sesión
SESSION_TOUCH_INTERVAL_SECONDS=30

# Minutos que dura el bloqueo de cuenta tras demasiados intentos fallidos
LOGIN_LOCK_DURATION_MINUTES=15

# Número máximo de intentos de login fallidos antes de bloquear la cuenta
LOGIN_MAX_FAILED_ATTEMPTS=5

# Minutos de validez del token de restablecimiento de contraseña
PASSWORD_RESET_TTL_MINUTES=60

# ─────────────────────────────────────────────
# Two-factor authentication (TOTP)
# ─────────────────────────────────────────────

# Nombre del emisor que aparece en la app autenticadora (ej. Google Authenticator)
TWO_FACTOR_ISSUER="${APP_NAME}"

# Minutos de validez de la sesión de configuración de 2FA
TWO_FACTOR_SETUP_TTL_MINUTES=10

# Segundos antes de rotar el QR durante la configuración de 2FA
TWO_FACTOR_SETUP_QR_ROTATE_SECONDS=120

# Minutos de validez del desafío de 2FA al iniciar sesión
TWO_FACTOR_LOGIN_CHALLENGE_TTL_MINUTES=10

# Intentos máximos para resolver el desafío de 2FA antes de invalidarlo
TWO_FACTOR_LOGIN_CHALLENGE_MAX_ATTEMPTS=5

# Cantidad de códigos de recuperación generados al activar 2FA
TWO_FACTOR_RECOVERY_CODES_COUNT=8

# Dígitos del código TOTP (6 u 8)
TWO_FACTOR_TOTP_DIGITS=6

# Segundos de vigencia de cada código TOTP
TWO_FACTOR_TOTP_PERIOD_SECONDS=30

# Ventana de tolerancia de períodos TOTP (1 = acepta el período anterior y el siguiente)
TWO_FACTOR_TOTP_WINDOW=1

# ─────────────────────────────────────────────
# Mail
# ─────────────────────────────────────────────

# Driver de correo: smtp | console | disabled
MAIL_DRIVER="smtp"

# Servidor SMTP saliente (solo cuando MAIL_DRIVER=smtp)
MAIL_HOST="smtp.gmail.com"

# Puerto SMTP (587 para STARTTLS, 465 para SSL)
MAIL_PORT="587"

# Usar conexión SSL directa en lugar de STARTTLS
MAIL_SECURE="false"

# Usuario de autenticación SMTP (solo cuando MAIL_DRIVER=smtp)
MAIL_USER="you@example.com"

# Contraseña o app-password del usuario SMTP (solo cuando MAIL_DRIVER=smtp)
MAIL_PASSWORD="your-smtp-password"

# Dirección que aparece en el campo "De" de los correos enviados
MAIL_FROM="you@example.com"

# ─────────────────────────────────────────────
# Symmetric encryption
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────

# Clave AES-256-GCM en hexadecimal (exactamente 64 caracteres = 32 bytes)
ENCRYPTION_KEY="change-me-64-hex-chars"

# ─────────────────────────────────────────────
# Documents / file storage
# ─────────────────────────────────────────────

# Ruta del directorio donde se almacenan los archivos subidos
DOCUMENTS_STORAGE_DIR="uploads/documents"

# Tamaño máximo permitido por archivo en megabytes
DOCUMENTS_MAX_FILE_SIZE_MB=20

# Tipos MIME aceptados, separados por coma
DOCUMENTS_ALLOWED_MIME_TYPES="application/pdf,image/jpeg,image/png,image/webp,text/plain"

# ─────────────────────────────────────────────
# Seed (initial admin user)
# ─────────────────────────────────────────────

# Nombre de usuario del administrador inicial creado por el seed
ADMIN_USERNAME="admin"

# Contraseña del administrador inicial (cámbiala después del primer login)
ADMIN_PASSWORD="ChangeMe123!"

# Nombre completo del administrador inicial
ADMIN_FULL_NAME="Administrator"

# ─────────────────────────────────────────────
# Docker Compose (optional overrides)
# ─────────────────────────────────────────────

# Base de datos local usada por docker-compose.yml
POSTGRES_DB="gas_backend"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_PORT=5432

# Puertos locales de Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Controla si el contenedor aplica schema sync y ejecuta el seed al arrancar
RUN_PRISMA_GENERATE=true
RUN_DB_PUSH=true
RUN_DB_SEED=true
