{
    "required": "{property} 是必填项",
    "string": "{property} 必须是有效文本",
    "minLength": "{property} 至少需要 {minLength} 个字符",
    "maxLength": "{property} 不能超过 {maxLength} 个字符",
    "password": "密码必须至少包含 8 个字符、一个大写字母、一个小写字母和一个数字",
    "boolean": "{property} 必须是 true 或 false",
    "array": "{property} 必须是数组",
    "minItems": "{property} 至少需要 {minSize} 个元素",
    "maxItems": "{property} 不能超过 {maxSize} 个元素",
    "date": "{property} 必须是有效日期",
    "isoDate": "{property} 必须是有效的 ISO 日期",
    "enum": "{property} 必须是允许的值之一",
    "integer": "{property} 必须是有效整数",
    "number": "{property} 必须是有效数字",
    "minValue": "{property} 必须大于或等于 {min}",
    "maxValue": "{property} 必须小于或等于 {max}",
    "uuid": "{property} 必须是有效 UUID"
}
