{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".e2e-spec.ts$",
    "moduleNameMapper": {
        "^@/(.*)$": "<rootDir>/../src/$1",
        "^argon2$": "<rootDir>/mocks/argon2.ts"
    },
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    }
}
