generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum UserStatus {
    active
    inactive
    suspended
}

enum OrganizationStatus {
    active
    inactive
}

enum NotificationType {
    info
    warning
    success
    error
}

enum EmailDispatchContext {
    password_reset
    welcome_credentials
    verify_email
    login_alert
    custom
}

enum EmailDispatchStatus {
    accepted
    sent
    failed
    suppressed_rate_limit
}

enum AuditActorType {
    user
    system
    anonymous
}

enum AuditChangeAction {
    create
    update
    delete
}

enum AuditLogLevel {
    info
    warning
    error
    critical
}

enum AuthAccessEventType {
    login_success
    login_failed
    two_factor_challenge_created
    two_factor_challenge_failed
    two_factor_verified
    logout
    logout_all
    refresh
    session_revoked
    access_denied
    password_reset_requested
    password_reset_completed
    email_verification_requested
    email_verification_completed
}

model User {
    id                        String                    @id @default(uuid())
    username                  String                    @unique
    email                     String?                   @unique
    fullName                  String
    passwordHash              String
    status                    UserStatus                @default(active)
    mustChangePassword        Boolean                   @default(false)
    requiresEmailVerification Boolean                   @default(false)
    emailVerifiedAt           DateTime?
    failedLoginAttempts       Int                       @default(0)
    lockedUntil               DateTime?
    lastLoginAt               DateTime?
    twoFactorEnabled          Boolean                   @default(false)
    twoFactorSecret           String?
    twoFactorPendingSecret    String?
    twoFactorPendingCreatedAt DateTime?
    twoFactorConfirmedAt      DateTime?
    createdAt                 DateTime                  @default(now())
    updatedAt                 DateTime                  @updatedAt
    deletedAt                 DateTime?

    accesses                  UserAccess[]
    auditDataChanges          AuditDataChange[]
    auditHttpRequests         AuditHttpRequest[]
    authAccessLogs            AuthAccessLog[]
    emailDispatchesAsActor    EmailDispatch[]           @relation("EmailDispatchTriggeredByUser")
    emailDispatchesAsTarget   EmailDispatch[]           @relation("EmailDispatchRecipientUser")
    emailVerificationTokens   EmailVerificationToken[]
    externalIdentities        ExternalIdentity[]
    notifications             Notification[]
    organizationMemberships   OrganizationMembership[]
    passwordResetTokens       PasswordResetToken[]
    refreshTokens             RefreshToken[]
    systemErrorLogs           SystemErrorLog[]
    twoFactorLoginChallenges  TwoFactorLoginChallenge[]
    twoFactorRecoveryCodes    TwoFactorRecoveryCode[]
    uploadedDocuments         Document[]

    @@index([status])
    @@index([twoFactorEnabled])
    @@index([deletedAt, createdAt])
    @@map("users")
}

model ExternalIdentity {
    id              String   @id @default(uuid())
    userId          String
    provider        String
    issuer          String
    providerSubject String
    email           String?
    emailVerified   Boolean  @default(false)
    lastLoginAt     DateTime?
    profile         Json?
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([provider, providerSubject])
    @@index([userId])
    @@index([provider, email])
    @@map("external_identities")
}

model AuditHttpRequest {
    id             String         @id @default(uuid())
    requestId      String?
    userId         String?
    actorType      AuditActorType @default(anonymous)
    method         String
    endpoint       String
    route          String?
    ipAddress      String?
    userAgent      String?
    headers        Json?
    query          Json?
    params         Json?
    requestBody    Json?
    responseStatus Int
    responseBody   Json?
    success        Boolean
    durationMs     Int?
    errorMessage   String?
    createdAt      DateTime       @default(now())

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

    @@index([requestId])
    @@index([userId, createdAt])
    @@index([method, createdAt])
    @@index([endpoint, createdAt])
    @@index([responseStatus, createdAt])
    @@index([success, createdAt])
    @@index([ipAddress, createdAt])
    @@map("audit_http_requests")
}

model AuditDataChange {
    id                String            @id @default(uuid())
    requestId         String?
    userId            String?
    changedByUsername String?
    actorType         AuditActorType    @default(anonymous)
    tableName         String
    recordId          String?
    action            AuditChangeAction
    beforeData        Json?
    afterData         Json?
    changedKeys       Json?
    reason            String?
    source            String?
    ipAddress         String?
    userAgent         String?
    createdAt         DateTime          @default(now())

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

    @@index([userId, createdAt])
    @@index([tableName, createdAt])
    @@index([recordId, createdAt])
    @@index([action, createdAt])
    @@index([requestId])
    @@index([source, createdAt])
    @@map("audit_data_changes")
}

model AuthAccessLog {
    id              String              @id @default(uuid())
    requestId       String?
    userId          String?
    usernameOrEmail String?
    eventType       AuthAccessEventType
    success         Boolean
    failureReason   String?
    ipAddress       String?
    userAgent       String?
    metadata        Json?
    createdAt       DateTime            @default(now())

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

    @@index([userId, createdAt])
    @@index([eventType, createdAt])
    @@index([success, createdAt])
    @@index([ipAddress, createdAt])
    @@index([requestId])
    @@map("auth_access_logs")
}

model SystemErrorLog {
    id        String        @id @default(uuid())
    requestId String?
    userId    String?
    level     AuditLogLevel @default(error)
    source    String?
    errorCode String?
    message   String
    stack     String?
    path      String?
    method    String?
    ipAddress String?
    userAgent String?
    context   Json?
    createdAt DateTime      @default(now())

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

    @@index([userId, createdAt])
    @@index([level, createdAt])
    @@index([source, createdAt])
    @@index([errorCode, createdAt])
    @@index([requestId])
    @@map("system_error_logs")
}

model Organization {
    id          String                   @id @default(uuid())
    name        String
    slug        String                   @unique
    description String?
    status      OrganizationStatus       @default(active)
    createdAt   DateTime                 @default(now())
    updatedAt   DateTime                 @updatedAt
    deletedAt   DateTime?

    documents   Document[]
    memberships OrganizationMembership[]
    userAccesses UserAccess[]

    @@index([status])
    @@index([name])
    @@index([deletedAt, createdAt])
    @@map("organizations")
}

model OrganizationMembership {
    id             String       @id @default(uuid())
    organizationId String
    userId         String
    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt
    deletedAt      DateTime?

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([organizationId])
    @@index([userId])
    @@index([organizationId, userId])
    @@index([deletedAt, createdAt])
    @@map("organization_memberships")
}

model RefreshToken {
    id             String    @id @default(uuid())
    userId         String
    tokenHash      String    @unique
    expiresAt      DateTime
    revokedAt      DateTime?
    lastActivityAt DateTime  @default(now())
    idleExpiresAt  DateTime
    userAgent      String?
    ipAddress      String?
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([userId])
    @@index([userId, revokedAt])
    @@index([userId, lastActivityAt])
    @@index([expiresAt])
    @@index([idleExpiresAt])
    @@map("refresh_tokens")
}

model PasswordResetToken {
    id        String    @id @default(uuid())
    userId    String
    tokenHash String    @unique
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([userId])
    @@index([expiresAt])
    @@map("password_reset_tokens")
}

model EmailVerificationToken {
    id        String    @id @default(uuid())
    userId    String
    tokenHash String    @unique
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([userId])
    @@index([expiresAt])
    @@map("email_verification_tokens")
}

model TwoFactorLoginChallenge {
    id            String    @id @default(uuid())
    userId        String
    challengeHash String    @unique
    expiresAt     DateTime
    consumedAt    DateTime?
    attemptCount  Int       @default(0)
    userAgent     String?
    ipAddress     String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([userId, createdAt])
    @@index([expiresAt])
    @@index([consumedAt])
    @@map("two_factor_login_challenges")
}

model TwoFactorRecoveryCode {
    id        String    @id @default(uuid())
    userId    String
    codeHash  String    @unique
    usedAt    DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([userId, usedAt, createdAt])
    @@map("two_factor_recovery_codes")
}

model Role {
    id          String           @id @default(uuid())
    code        String           @unique
    name        String
    description String?
    createdAt   DateTime         @default(now())
    updatedAt   DateTime         @updatedAt
    deletedAt   DateTime?

    accesses    UserAccess[]
    permissions RolePermission[]

    @@index([deletedAt, createdAt])
    @@map("roles")
}

model Permission {
    id          String           @id @default(uuid())
    code        String           @unique
    name        String?
    description String?
    createdAt   DateTime         @default(now())
    updatedAt   DateTime         @updatedAt
    deletedAt   DateTime?

    roles RolePermission[]

    @@index([deletedAt, createdAt])
    @@map("permissions")
}

model RolePermission {
    roleId       String
    permissionId String
    createdAt    DateTime   @default(now())

    role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@id([roleId, permissionId])
    @@map("role_permissions")
}

model UserAccess {
    id             String    @id @default(uuid())
    userId         String
    roleId         String
    organizationId String?
    scopeKey       String?
    scopeId        String?
    assignedAt     DateTime  @default(now())
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt
    deletedAt      DateTime?

    user         User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    role         Role          @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
    organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([userId])
    @@index([roleId])
    @@index([organizationId])
    @@index([scopeKey, scopeId])
    @@index([userId, roleId, scopeKey, scopeId])
    @@index([deletedAt, createdAt])
    @@map("user_accesses")
}

model Address {
    id             String   @id @default(uuid())
    street         String?
    exteriorNumber String?
    interiorNumber String?
    neighborhood   String?
    municipality   String?
    city           String?
    state          String?
    country        String?
    postalCode     String?
    references     String?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@map("addresses")
}

model Notification {
    id        String           @id @default(uuid())
    userId    String
    title     String
    message   String
    detail    String?
    type      NotificationType @default(info)
    link      String?
    isRead    Boolean          @default(false)
    readAt    DateTime?
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt
    deletedAt DateTime?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([userId])
    @@index([userId, isRead])
    @@index([userId, createdAt])
    @@index([userId, isRead, createdAt])
    @@index([userId, deletedAt, createdAt])
    @@map("notifications")
}

model Document {
    id               String    @id @default(uuid())
    uploadedByUserId String?
    organizationId   String?
    title            String
    description      String?
    category         String?
    entityType       String?
    entityId         String?
    scopeKey         String?
    scopeId          String?
    originalName     String
    storageKey       String    @unique
    mimeType         String
    extension        String?
    sizeBytes        Int
    checksumSha256   String?
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt
    deletedAt        DateTime?

    uploadedByUser User?         @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
    organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

    @@index([uploadedByUserId])
    @@index([organizationId])
    @@index([entityType, entityId])
    @@index([scopeKey, scopeId])
    @@index([category])
    @@index([mimeType])
    @@index([deletedAt, createdAt])
    @@map("documents")
}

model EmailDispatch {
    id                String               @id @default(uuid())
    context           EmailDispatchContext
    status            EmailDispatchStatus
    recipientEmail    String?
    recipientUserId   String?
    triggeredByUserId String?
    ipAddress         String?
    reason            String?
    retryAfterSeconds Int?
    errorMessage      String?
    metadata          Json?
    createdAt         DateTime             @default(now())
    updatedAt         DateTime             @updatedAt

    recipientUser   User? @relation("EmailDispatchRecipientUser", fields: [recipientUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
    triggeredByUser User? @relation("EmailDispatchTriggeredByUser", fields: [triggeredByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

    @@index([context, createdAt])
    @@index([context, status, createdAt])
    @@index([recipientEmail, createdAt])
    @@index([recipientUserId, createdAt])
    @@index([triggeredByUserId, createdAt])
    @@index([ipAddress, createdAt])
    @@map("email_dispatches")
}
