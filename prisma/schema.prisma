generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  inactive
  suspended
}

enum OrganizationStatus {
  active
  inactive
}

enum NotificationType {
  info
  warning
  success
  error
}

enum EmailDispatchContext {
  password_reset
  welcome_credentials
  verify_email
  login_alert
  custom
}

enum EmailDispatchStatus {
  accepted
  sent
  failed
  suppressed_rate_limit
}

enum OrganizationInvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum SettingScope {
  global
  organization
}

model User {
  id                        String     @id @default(uuid())
  username                  String
  email                     String?
  fullName                  String
  preferredLanguage         String     @default("es")
  passwordHash              String
  status                    UserStatus @default(active)
  mustChangePassword        Boolean    @default(false)
  requiresEmailVerification Boolean    @default(false)
  emailVerifiedAt           DateTime?
  failedLoginAttempts       Int        @default(0)
  lockedUntil               DateTime?
  lastLoginAt               DateTime?
  twoFactorEnabled          Boolean    @default(false)
  twoFactorSecret           String?
  twoFactorPendingSecret    String?
  twoFactorPendingCreatedAt DateTime?
  twoFactorConfirmedAt      DateTime?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  deletedAt                 DateTime?

  accesses                        UserAccess[]
  emailDispatchesAsActor          EmailDispatch[]           @relation("EmailDispatchTriggeredByUser")
  emailDispatchesAsTarget         EmailDispatch[]           @relation("EmailDispatchRecipientUser")
  emailVerificationTokens         EmailVerificationToken[]
  externalIdentities              ExternalIdentity[]
  notifications                   Notification[]
  organizationMemberships         OrganizationMembership[]
  organizationInvitationsAccepted OrganizationInvitation[]  @relation("OrganizationInvitationAcceptedByUser")
  organizationInvitationsCreated  OrganizationInvitation[]  @relation("OrganizationInvitationCreatedByUser")
  passwordResetTokens             PasswordResetToken[]
  refreshTokens                   RefreshToken[]
  sessions                        Session[]
  settingsCreated                 Setting[]                 @relation("SettingCreatedByUser")
  settingsDeleted                 Setting[]                 @relation("SettingDeletedByUser")
  settingsUpdated                 Setting[]                 @relation("SettingUpdatedByUser")
  twoFactorLoginChallenges        TwoFactorLoginChallenge[]
  twoFactorRecoveryCodes          TwoFactorRecoveryCode[]
  organizationsCreated            Organization[]            @relation("OrganizationCreatedByUser")
  organizationsDeleted            Organization[]            @relation("OrganizationDeletedByUser")
  organizationsUpdated            Organization[]            @relation("OrganizationUpdatedByUser")
  rolesCreated                    Role[]                    @relation("RoleCreatedByUser")
  rolesDeleted                    Role[]                    @relation("RoleDeletedByUser")
  rolesUpdated                    Role[]                    @relation("RoleUpdatedByUser")
  permissionsCreated              Permission[]              @relation("PermissionCreatedByUser")
  permissionsDeleted              Permission[]              @relation("PermissionDeletedByUser")
  permissionsUpdated              Permission[]              @relation("PermissionUpdatedByUser")
  documentsCreated                Document[]                @relation("DocumentCreatedByUser")
  documentsDeleted                Document[]                @relation("DocumentDeletedByUser")
  documentsUpdated                Document[]                @relation("DocumentUpdatedByUser")
  uploadedDocuments               Document[]
  notificationsCreated            Notification[]            @relation("NotificationCreatedByUser")
  notificationsDeleted            Notification[]            @relation("NotificationDeletedByUser")
  notificationsUpdated            Notification[]            @relation("NotificationUpdatedByUser")

  @@index([username])
  @@index([email])
  @@index([status])
  @@index([twoFactorEnabled])
  @@index([deletedAt, createdAt])
  @@map("users")
}

model ExternalIdentity {
  id              String    @id @default(uuid())
  userId          String
  provider        String
  issuer          String
  providerSubject String
  email           String?
  emailVerified   Boolean   @default(false)
  lastLoginAt     DateTime?
  profile         Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([provider, email])
  @@map("external_identities")
}

model Organization {
  id              String             @id @default(uuid())
  name            String
  slug            String
  description     String?
  status          OrganizationStatus @default(active)
  createdByUserId String?
  updatedByUserId String?
  deletedByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  createdByUser User?                    @relation("OrganizationCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedByUser User?                    @relation("OrganizationUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedByUser User?                    @relation("OrganizationDeletedByUser", fields: [deletedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  documents     Document[]
  invitations   OrganizationInvitation[]
  memberships   OrganizationMembership[]
  settings      Setting[]
  sessions      Session[]
  userAccesses  UserAccess[]

  @@index([status])
  @@index([name])
  @@index([slug])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
  @@index([deletedAt, createdAt])
  @@map("organizations")
}

model OrganizationMembership {
  id             String    @id @default(uuid())
  organizationId String
  userId         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, userId])
  @@index([deletedAt, createdAt])
  @@map("organization_memberships")
}

model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  sessionId      String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  lastActivityAt DateTime  @default(now())
  idleExpiresAt  DateTime
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([userId, revokedAt])
  @@index([userId, lastActivityAt])
  @@index([expiresAt])
  @@index([idleExpiresAt])
  @@map("refresh_tokens")
}

model Session {
  id             String    @id @default(uuid())
  userId         String
  organizationId String?
  revokedAt      DateTime?
  lastActivityAt DateTime  @default(now())
  idleExpiresAt  DateTime
  expiresAt      DateTime
  userAgent      String?
  ipAddress      String?
  deviceName     String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([organizationId])
  @@index([userId, revokedAt])
  @@index([lastActivityAt])
  @@index([expiresAt])
  @@index([idleExpiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model TwoFactorLoginChallenge {
  id            String    @id @default(uuid())
  userId        String
  challengeHash String    @unique
  expiresAt     DateTime
  consumedAt    DateTime?
  attemptCount  Int       @default(0)
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("two_factor_login_challenges")
}

model TwoFactorRecoveryCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, usedAt, createdAt])
  @@map("two_factor_recovery_codes")
}

model Role {
  id              String    @id @default(uuid())
  code            String
  name            String
  description     String?
  createdByUserId String?
  updatedByUserId String?
  deletedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  createdByUser User?                    @relation("RoleCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedByUser User?                    @relation("RoleUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedByUser User?                    @relation("RoleDeletedByUser", fields: [deletedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  accesses      UserAccess[]
  invitations   OrganizationInvitation[]
  permissions   RolePermission[]

  @@index([code])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
  @@index([deletedAt, createdAt])
  @@map("roles")
}

model Permission {
  id              String    @id @default(uuid())
  code            String
  name            String?
  description     String?
  createdByUserId String?
  updatedByUserId String?
  deletedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  createdByUser User?            @relation("PermissionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedByUser User?            @relation("PermissionUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedByUser User?            @relation("PermissionDeletedByUser", fields: [deletedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  roles         RolePermission[]

  @@index([code])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
  @@index([deletedAt, createdAt])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserAccess {
  id             String    @id @default(uuid())
  userId         String
  roleId         String
  organizationId String?
  scopeKey       String?
  scopeId        String?
  assignedAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role         Role          @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([roleId])
  @@index([organizationId])
  @@index([scopeKey, scopeId])
  @@index([userId, roleId, scopeKey, scopeId])
  @@index([deletedAt, createdAt])
  @@map("user_accesses")
}

model Address {
  id             String   @id @default(uuid())
  street         String?
  exteriorNumber String?
  interiorNumber String?
  neighborhood   String?
  municipality   String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  references     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("addresses")
}

model Notification {
  id              String           @id @default(uuid())
  userId          String
  createdByUserId String?
  updatedByUserId String?
  deletedByUserId String?
  title           String
  message         String
  detail          String?
  type            NotificationType @default(info)
  link            String?
  isRead          Boolean          @default(false)
  readAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdByUser User? @relation("NotificationCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedByUser User? @relation("NotificationUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedByUser User? @relation("NotificationDeletedByUser", fields: [deletedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
  @@index([userId, deletedAt, createdAt])
  @@map("notifications")
}

model Document {
  id               String    @id @default(uuid())
  uploadedByUserId String?
  organizationId   String?
  createdByUserId  String?
  updatedByUserId  String?
  deletedByUserId  String?
  title            String
  description      String?
  category         String?
  entityType       String?
  entityId         String?
  scopeKey         String?
  scopeId          String?
  originalName     String
  storageKey       String    @unique
  mimeType         String
  extension        String?
  sizeBytes        Int
  checksumSha256   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  uploadedByUser User?         @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdByUser  User?         @relation("DocumentCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedByUser  User?         @relation("DocumentUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedByUser  User?         @relation("DocumentDeletedByUser", fields: [deletedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([uploadedByUserId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([scopeKey, scopeId])
  @@index([category])
  @@index([mimeType])
  @@index([deletedAt, createdAt])
  @@map("documents")
}

model OrganizationInvitation {
  id               String                       @id @default(uuid())
  organizationId   String
  roleId           String?
  email            String
  tokenHash        String                       @unique
  status           OrganizationInvitationStatus @default(pending)
  invitedByUserId  String?
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  invitedByUser  User?        @relation("OrganizationInvitationCreatedByUser", fields: [invitedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  acceptedByUser User?        @relation("OrganizationInvitationAcceptedByUser", fields: [acceptedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([organizationId])
  @@index([roleId])
  @@index([email])
  @@index([status, createdAt])
  @@index([expiresAt])
  @@index([invitedByUserId])
  @@index([acceptedByUserId])
  @@map("organization_invitations")
}

model Setting {
  id              String       @id @default(uuid())
  key             String
  value           Json
  description     String?
  scope           SettingScope @default(global)
  organizationId  String?
  createdByUserId String?
  updatedByUserId String?
  deletedByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdByUser User?         @relation("SettingCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedByUser User?         @relation("SettingUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedByUser User?         @relation("SettingDeletedByUser", fields: [deletedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([key])
  @@index([scope, organizationId])
  @@index([organizationId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
  @@index([deletedAt, createdAt])
  @@map("settings")
}

model EmailDispatch {
  id                String               @id @default(uuid())
  context           EmailDispatchContext
  status            EmailDispatchStatus
  recipientEmail    String?
  recipientUserId   String?
  triggeredByUserId String?
  ipAddress         String?
  reason            String?
  retryAfterSeconds Int?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  recipientUser   User? @relation("EmailDispatchRecipientUser", fields: [recipientUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  triggeredByUser User? @relation("EmailDispatchTriggeredByUser", fields: [triggeredByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([context, createdAt])
  @@index([context, status, createdAt])
  @@index([recipientEmail, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([triggeredByUserId, createdAt])
  @@index([ipAddress, createdAt])
  @@map("email_dispatches")
}
